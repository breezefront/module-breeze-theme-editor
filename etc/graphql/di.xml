<?xml version="1.0"?>
<!--
/**
 * GraphQL Dependency Injection Configuration
 * 
 * Registers plugins for GraphQL operations
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <!-- 
        Plugin: ACL Authorization for BreezeThemeEditor GraphQL resolvers
        
        Intercepts all resolvers implementing Swissup\BreezeThemeEditor\Api\GraphQL\ResolverInterface
        and validates:
        1. User is authenticated (UserType === ADMIN)
        2. User has required ACL permission (via getAclResource())
        
        Similar to admin controller _isAllowed() pattern.
    -->
    <type name="Swissup\BreezeThemeEditor\Api\GraphQL\ResolverInterface">
        <plugin name="breeze_theme_editor_acl_authorization" 
                type="Swissup\BreezeThemeEditor\Plugin\GraphQL\AclAuthorization" 
                sortOrder="10"
                disabled="false"/>
    </type>

    <!-- Cache invalidation plugins (must live in graphql/di.xml, not frontend/di.xml,
         because GraphQL requests run in the "graphql" area, not "frontend") -->

    <!-- Invalidate block cache after saving draft values -->
    <type name="Swissup\BreezeThemeEditor\Model\Resolver\Mutation\SaveValues">
        <plugin name="swissup_bte_invalidate_cache_after_save"
                type="Swissup\BreezeThemeEditor\Plugin\Mutation\InvalidateCacheAfterMutation"
                sortOrder="100"/>
    </type>

    <!-- Invalidate block cache + FPC after publishing -->
    <type name="Swissup\BreezeThemeEditor\Model\Resolver\Mutation\Publish">
        <plugin name="swissup_bte_invalidate_cache_after_publish"
                type="Swissup\BreezeThemeEditor\Plugin\Mutation\InvalidateCacheAfterMutation"
                sortOrder="100"/>
    </type>

    <!-- Invalidate block cache + FPC after rollback -->
    <type name="Swissup\BreezeThemeEditor\Model\Resolver\Mutation\Rollback">
        <plugin name="swissup_bte_invalidate_cache_after_rollback"
                type="Swissup\BreezeThemeEditor\Plugin\Mutation\InvalidateCacheAfterMutation"
                sortOrder="100"/>
    </type>
</config>
