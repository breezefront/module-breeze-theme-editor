<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <!--
        Set theme preview and store cookies when the frontend page is loaded inside
        the BTE editor iframe.

        The admin Iframe controller appends '___store=<code>' to every frontend URL
        it builds. This observer catches that parameter on the frontend side and writes
        the Magento-standard 'store' and 'preview_theme' cookies so that:
        - Navigating within the iframe stays on the correct store view
        - The correct theme is previewed (read from design/theme/theme_id config)
        - F5 refresh inside the iframe works correctly

        Guard: the observer exits immediately when '___store' is absent, so it adds
        zero overhead on normal frontend requests.
    -->
    <event name="controller_action_predispatch">
        <observer name="swissup_breeze_theme_editor_set_theme_preview_cookie" instance="Swissup\BreezeThemeEditor\Observer\SetThemePreviewCookie" />
    </event>
</config>
