<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- CSS Variables in head.additional so they get copied to iframe -->
        <referenceBlock name="head.additional">
            <block class="Swissup\BreezeThemeEditor\Block\ThemeCssVariables"
                   name="bte.theme.css.variables"
                   after="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">Swissup\BreezeThemeEditor\ViewModel\ThemeCssVariables</argument>
                </arguments>
            </block>
        </referenceBlock>
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="breeze_theme_editor_toolbar"
                   template="Swissup_BreezeThemeEditor::toolbar.phtml"
                   before="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">Swissup\BreezeThemeEditor\ViewModel\Toolbar</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
