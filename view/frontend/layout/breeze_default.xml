<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="breeze.js">
          <arguments>
            <argument name="bundles" xsi:type="array">
              <item name="dynamic" xsi:type="array">
                <item name="items" xsi:type="array">
                  <item name="Swissup_BreezeThemeEditor/js/*" xsi:type="string">Swissup_BreezeThemeEditor/js/*</item>
                </item>
              </item>
            </argument>
          </arguments>
        </referenceBlock>
        
        <!-- Test Runner (activated with ?jstest=true URL parameter) -->
        <referenceContainer name="after.body.start">
            <block 
                class="Swissup\BreezeThemeEditor\Block\TestRunner" 
                name="breeze.test.runner" 
                template="Swissup_BreezeThemeEditor::test-runner.phtml"
            />
        </referenceContainer>
    </body>
</page>
