<?php
/**
 * Breeze Theme Editor: Inline CSS Variables
 * 
 * Renders PUBLISHED CSS only. Draft CSS is created dynamically by JavaScript.
 * 
 * @var \Swissup\BreezeThemeEditor\Block\ThemeCssVariables $block
 */
$viewModel = $block->getViewModel();
$inlineCssContent = $viewModel->getInlineCssContent();

// Skip rendering if module disabled or no CSS content
if (empty($inlineCssContent) || $inlineCssContent === ":root {\n}\n") {
    return;
}
?>
<!-- Breeze Theme Editor: Published CSS -->
<style id="bte-theme-css-variables" data-status="published" media="all">
<?= /* @noEscape */ $inlineCssContent ?>
</style>
