<?php
/**
 * @var $block \Magento\Backend\Block\Template
 * @var $viewModel \Swissup\BreezeThemeEditor\ViewModel\AdminToolbar
 */
$viewModel = $block->getData('view_model');

// Get store ID from ViewModel (same source as toolbar config for consistency)
// Uses priority: URL param ?store=X → Cookie → Default store
$storeId = $viewModel ? $viewModel->getStoreId() : 1;
$jstest = $block->getData('jstest') ?: false;

// Get full toolbar configuration from ViewModel
$toolbarConfig = $viewModel ? $viewModel->getToolbarConfig() : [];

// Read 'url' parameter from GET (priority for URL sharing)
// If not present, will be restored from localStorage via JavaScript
$requestedUrl = $block->getRequest()->getParam('url', '/');

// Build iframe URL (theme is determined automatically from store config)
$iframeUrl = $block->getUrl('breeze_editor/editor/iframe', [
    'store' => $storeId,
    'url' => $requestedUrl,
    'jstest' => $jstest
]);
?>

<!-- Minimal HTML structure - components will render their own UI -->
<div id="bte-admin-editor" class="bte-admin-editor">
    <!-- Toolbar container - populated by toolbar.js -->
    <div id="breeze-theme-editor-toolbar"></div>
    
    <!-- Panels container - for side panels (theme editor, etc) -->
    <!-- Empty panels - widgets will render all HTML including headers/close buttons -->
    <div id="bte-panels-container" class="bte-panels">
        <!-- Theme Editor Panel - empty, widget renders everything -->
        <div id="theme-editor-panel" class="bte-panel" style="display: none;"></div>

        <!-- Content Builder Panel - empty, widget renders everything -->
        <div id="content-builder-panel" class="bte-panel" style="display: none;"></div>
    </div>
    
    <!-- BCB right property panel — mounted here by bcb-panel.js, hidden by default -->
    <div id="bcb-right-panel" class="bcb-right-panel"></div>

    <!-- Iframe container -->
    <div id="bte-preview" class="bte-preview">
        <iframe 
            id="bte-iframe"
            src="<?= $block->escapeUrl($iframeUrl) ?>"
            frameborder="0"
            sandbox="allow-same-origin allow-scripts allow-forms allow-popups"
        ></iframe>
    </div>
</div>

<!-- Component-based initialization via x-magento-init -->
<script type="text/x-magento-init">
{
    "#bte-admin-editor": {
        "Swissup_BreezeThemeEditor/js/editor/toolbar": <?= /* @noEscape */ json_encode($toolbarConfig) ?>
    }
}
</script>

<!-- URL restoration from localStorage -->
<script>
require([
    'jquery',
    'Swissup_BreezeThemeEditor/js/editor/utils/browser/storage-helper'
], function($, StorageHelper) {
    'use strict';
    
    // Initialize StorageHelper with current store/theme
    var toolbarConfig = <?= /* @noEscape */ json_encode($toolbarConfig) ?>;
    if (toolbarConfig.storeId && toolbarConfig.themeId) {
        StorageHelper.init(toolbarConfig.storeId, toolbarConfig.themeId);
    }
    
    // If URL parameter is '/' (default), try to restore from localStorage
    var urlParams = new URLSearchParams(window.location.search);
    var urlParam = urlParams.get('url');

    if (!urlParam || urlParam === '/' || urlParam === '%2F') {
        var savedUrl = StorageHelper.getCurrentUrl();

        // Validate: reject any URL that looks like an admin/proxy URL or is
        // corrupted (double/triple-encoded slashes are a sure sign of a
        // previously saved proxy URL that got URL-encoded recursively).
        var adminBasePath = toolbarConfig.adminBasePath || '/admin/';
        var isCorrupted = !savedUrl
            || savedUrl === '/'
            || savedUrl.indexOf(adminBasePath) !== -1
            || savedUrl.indexOf('%2F') !== -1
            || savedUrl.indexOf('%25') !== -1;

        if (isCorrupted && savedUrl && savedUrl !== '/') {
            // Clear the bad value so it doesn't cause problems on future loads
            StorageHelper.setCurrentUrl('/');
            savedUrl = '/';
        }

        if (savedUrl && savedUrl !== '/') {
            // Update iframe src with saved URL
            var $iframe = $('#bte-iframe');
            var currentSrc = $iframe.attr('src');

            // Replace /url/%2F/ or /url/.../ with /url/{encoded_path}/
            var encodedUrl = encodeURIComponent(savedUrl);
            var newSrc = currentSrc.replace(/\/url\/[^\/]+\//, '/url/' + encodedUrl + '/');

            $iframe.attr('src', newSrc);
        }
    }
});
</script>

